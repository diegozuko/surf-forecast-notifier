{
  "name": "surf-forecast-notifier",
  "version": "1.0.0",
  "description": "Surf Forecast Notifier MVP – Daily longboard forecast for Punta del Este via Telegram",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "forecast": "tsx src/cli.ts forecast",
    "demo": "DEMO_MODE=true tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["surf", "forecast", "telegram", "longboard", "punta-del-este"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "canvas": "^3.1.0",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/suncalc": "^1.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
