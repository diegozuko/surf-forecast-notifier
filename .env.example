# === Surf Forecast Notifier – Environment Variables ===

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Telegram Chat ID (your user or group chat ID)
TELEGRAM_CHAT_ID=your-chat-id

# Timezone (do not change unless you relocate)
TZ=America/Montevideo

# Forecast provider API key (optional – Open-Meteo is free, no key needed)
# Only needed if you switch to Stormglass or similar
FORECAST_PROVIDER_KEY=

# Demo mode – uses fixtures instead of real API calls
DEMO_MODE=false

# Schedule time (HH:MM in local timezone)
SCHEDULE_TIME=21:30

# Animation feature flag
ANIMATION_ENABLED=false
